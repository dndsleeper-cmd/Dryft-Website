# Dryft API — environment variables
#
# These are stored in the Vercel dashboard (Project Settings → Environment
# Variables) and exposed to the serverless functions at runtime.
# DO NOT commit a real .env file. This .example file is for reference.

# === Firebase Admin SDK service account ===================================
# Get these from the Firebase Console:
#   Project Settings → Service accounts → Generate new private key
# Then open the downloaded JSON and copy the three fields below.
#
# IMPORTANT: FIREBASE_PRIVATE_KEY contains literal \n escape sequences in the
# JSON file. Vercel preserves them as backslash-n; the runtime unescapes them
# to real newlines. Paste the key INCLUDING the BEGIN/END lines, exactly as it
# appears in the JSON (surrounding quotes optional in the Vercel UI).
FIREBASE_PROJECT_ID=your-project-id
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your-project-id.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nMIIE...\n-----END PRIVATE KEY-----\n"

# === IP hashing salt =======================================================
# A random 32+ char string used to hash IP addresses before storage. Lets us
# do abuse correlation (same IP, many submits) without holding plaintext IPs.
# Rotate this only when you're OK losing historical correlation.
# Generate with: openssl rand -hex 32
IP_HASH_SALT=replace-with-32-byte-random-hex

# Dryft API — environment variables
#
# These are stored in the Vercel dashboard (Project Settings → Environment
# Variables) and exposed to the serverless functions at runtime.
# DO NOT commit a real .env file. This .example file is for reference.

# === Firebase Admin SDK service account ===================================
# Get these from the Firebase Console:
#   Project Settings → Service accounts → Generate new private key
# Then open the downloaded JSON and copy the three fields below.
#
# IMPORTANT: FIREBASE_PRIVATE_KEY contains literal \n escape sequences in the
# JSON file. Vercel preserves them as backslash-n; the runtime unescapes them
# to real newlines. Paste the key INCLUDING the BEGIN/END lines, exactly as it
# appears in the JSON (surrounding quotes optional in the Vercel UI).
FIREBASE_PROJECT_ID=your-project-id
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your-project-id.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nMIIE...\n-----END PRIVATE KEY-----\n"

# === IP hashing salt =======================================================
# A random 32+ char string used to hash IP addresses before storage. Lets us
# do abuse correlation (same IP, many submits) without holding plaintext IPs.
# Rotate this only when you're OK losing historical correlation.
# Generate with: openssl rand -hex 32
IP_HASH_SALT=replace-with-32-byte-random-hex

# === reCAPTCHA v3 (App Check) ==============================================
# Register a v3 site at https://www.google.com/recaptcha/admin
#   Domain: thedryft.com
#   Type:   reCAPTCHA v3
# Google gives you a site key (public, goes in index.html <meta>) and a
# secret key (server-only, goes here). Until BOTH are configured the
# verification is skipped — endpoints work but get no bot protection.
RECAPTCHA_SECRET_KEY=

# === Upstash Redis — distributed rate limit ================================
# Provision a free Redis at https://console.upstash.com/redis
# Region: pick one close to your Vercel deployment.
# Copy the "REST API" URL and Token (NOT the redis:// connection string).
# When unset, the API falls back to in-memory rate limiting on warm
# serverless instances — catches obvious bursts but not coordinated abuse.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# === Dashboard admin token =================================================
# Gates GET /api/metrics, which powers the private /dashboard page.
# Until this is set, /api/metrics returns 503 and the dashboard stays locked.
# Generate with: openssl rand -hex 32
# Then open /dashboard and paste the same value to sign in.
DASHBOARD_TOKEN=

# === GA4 funnel on the dashboard (optional) ================================
# Lets /api/metrics pull the visitor funnel from Google Analytics on each
# dashboard refresh. Find the NUMERIC Property ID in GA4 → Admin → Property
# settings (looks like 123456789, NOT the G-XXXX Measurement ID).
# Also required, one-time: in GA4 → Admin → Property Access Management, add the
# FIREBASE_CLIENT_EMAIL service account as a Viewer, and enable the
# "Google Analytics Data API" in the Google Cloud project. Leave blank to skip.
GA4_PROPERTY_ID=
